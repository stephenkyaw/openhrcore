# ── Database ──────────────────────────────────────────────────────────────────
# For Docker: use service names (postgres, redis, minio)
# For local dev: use localhost
DATABASE_URL=postgresql+asyncpg://openhrcore:openhrcore@localhost:5432/openhrcore

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak / Auth ──────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=openhrcore
KEYCLOAK_CLIENT_ID=openhrcore-api

# ── S3-compatible object storage (MinIO in dev) ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=openhrcore

# ── AI integration ───────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=sk-change-me
AI_MODEL=gpt-4o

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=OpenHRCore
DEBUG=true
LOG_LEVEL=DEBUG

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Set AUTH_DEV_MODE=true to bypass login when no token is provided (dev only).
# JWT_SECRET is used to sign/verify locally issued JWTs.
AUTH_DEV_MODE=false
JWT_SECRET=openhrcore-dev-secret-change-in-production
