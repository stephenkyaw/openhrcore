# App
APP_NAME=OpenHRCore
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma separated origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# Database
DATABASE_URL=postgresql+asyncpg://openhrcore:openhrcore@localhost:5432/openhrcore
